		"eslint-import-resolver-typescript": "^4.4.4",
		"husky": "^9.1.7",
		"is-ci": "^4.1.0",
		"lint-staged": "^16.2.7",
		"lodash.merge": "^4.6.2",
		"prettier": "^3.8.1",
		"tsup": "^8.5.1",
		"turbo": "^2.8.10",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.56.0",
		"vitest": "^4.0.18"
	},
	"engines": {
		"node": ">=22.12.0"
	},
	"packageManager": "pnpm@10.30.1"
